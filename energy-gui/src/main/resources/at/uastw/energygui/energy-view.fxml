<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="10" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="at.uastw.energygui.EnergyController">
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <Label text="Current Energy Data" style="-fx-font-weight: bold;"/>
    <Button text="Refresh" onAction="#onRefreshClicked"/>
    <Label fx:id="lb_current" text="-"/>

    <Label text="Historical Data" style="-fx-font-weight: bold;"/>
    <Label text="Start:"/>
    <TextField fx:id="tf_start" promptText="2025-01-10T10:00:00"/>
    <Label text="End:"/>
    <TextField fx:id="tf_end" promptText="2025-01-10T14:00:00"/>
    <Button text="Load Historical Data" onAction="#onLoadHistoricalClicked"/>
    <TextArea fx:id="ta_historical" prefHeight="200" editable="false"/>

</VBox>
