<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="10" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="at.uastw.energygui.EnergyController">
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <Label text="Current Energy Data" style="-fx-font-weight: bold;"/>
    <Button text="Refresh" onAction="#onRefreshClicked"/>
    <ListView fx:id="lv_current" prefHeight="100"/>

    <Label text="Historical Data" style="-fx-font-weight: bold;"/>
    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label text="Start:"/>
        <DatePicker fx:id="dp_start"/>
        <ComboBox fx:id="cb_start_hour" promptText="Stunde"/>
    </HBox>
    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label text="End:"/>
        <DatePicker fx:id="dp_end"/>
        <ComboBox fx:id="cb_end_hour" promptText="Stunde"/>
    </HBox>
    <Button text="Load Historical Data" onAction="#onLoadHistoricalClicked"/>
    <ListView fx:id="lv_historical" prefHeight="200"/>

</VBox>